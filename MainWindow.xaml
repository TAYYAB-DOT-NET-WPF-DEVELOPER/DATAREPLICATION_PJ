<Window x:Class="DataIntegration.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DataIntegration"
        mc:Ignorable="d"
        Title="Pixel Data Integration Dashboard"
        Height="650" 
        Width="950"
        Background="#0F0F1A"
        WindowStartupLocation="CenterScreen" 
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanMinimize">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <!-- Color Palette -->
        <SolidColorBrush x:Key="BgDark" Color="#0F0F1A"/>
        <SolidColorBrush x:Key="BgCard" Color="#181826"/>
        <SolidColorBrush x:Key="BgInput" Color="#222235"/>
        <SolidColorBrush x:Key="TextLight" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="TextMuted" Color="#94A3B8"/>
        <SolidColorBrush x:Key="AccentTeal" Color="#0D9488"/>
        <SolidColorBrush x:Key="AccentTealHover" Color="#0F766E"/>
        <SolidColorBrush x:Key="BorderColor" Color="#2E2E42"/>

        <LinearGradientBrush x:Key="ButtonGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0D9488" Offset="0"/>
            <GradientStop Color="#115E59" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ProgressGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#06B6D4" Offset="0"/>
            <GradientStop Color="#10B981" Offset="1"/>
        </LinearGradientBrush>

        <!-- Modern ScrollViewer Style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Bg" SnapsToDevicePixels="true">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.Thumb>
                                    <Thumb Background="#374151" MinHeight="40" Margin="2,0">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom modern CheckBox Style -->
        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid x:Name="CheckBoxGrid" Background="Transparent" Cursor="Hand">
                            <Border x:Name="Box" Width="20" Height="20" CornerRadius="5" Background="#222235" BorderBrush="#3F3F5F" BorderThickness="1.5">
                                <Path x:Name="Check" Data="M3,7 L6,10 L11,4" Stroke="#0D9488" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#1E293B"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="#0D9488"/>
                                <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#0D9488"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        <!-- Custom thin ProgressBar Style -->
        <Style x:Key="ModernProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Background" Value="#1E1E2F"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot">
                            <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                            <Border x:Name="PART_Indicator" Background="{StaticResource ProgressGradient}" CornerRadius="3" HorizontalAlignment="Left"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" Background="{StaticResource BgDark}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1.5">
        <Grid>
            <Grid.RowDefinitions>
                <!-- Title Bar -->
                <RowDefinition Height="60"/>
                <!-- Main Content -->
                <RowDefinition Height="*"/>
                <!-- Footer Status Bar -->
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <!-- 1. Title Bar -->
            <Grid Grid.Row="0" Background="#131322" MouseDown="TitleBar_MouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                    <Ellipse Width="12" Height="12" Fill="#0D9488" Margin="0,0,10,0"/>
                    <TextBlock Text="PIXEL DATA INTEGRATION" FontSize="18" FontWeight="ExtraBold" Foreground="{StaticResource TextLight}" VerticalAlignment="Center"/>
                    <Border Background="#1E293B" CornerRadius="4" Margin="12,0,0,0" Padding="6,2" VerticalAlignment="Center">
                        <TextBlock Text="v2.1" FontSize="10" FontWeight="Bold" Foreground="#0D9488"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                    <!-- Minimize Button -->
                    <Button Click="MinimizeButton_Click" Content="—" Width="40" Height="40" Background="Transparent" Foreground="{StaticResource TextMuted}" FontSize="16" BorderThickness="0" Cursor="Hand" Margin="0,0,5,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
                                        <Setter Property="Background" Value="#222235"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="20"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <!-- Close Button -->
                    <Button Command="{Binding CloseWindowCommand}" Content="✕" Width="40" Height="40" Background="Transparent" Foreground="{StaticResource TextMuted}" FontSize="16" BorderThickness="0" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#EF4444"/>
                                        <Setter Property="Background" Value="#251C24"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="20"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- 2. Main Content Area -->
            <Grid Grid.Row="1" Margin="15,15,15,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Panel: Controls Card -->
                <Border Grid.Column="0" Background="{StaticResource BgCard}" CornerRadius="10" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Padding="20" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="Manual Sync Control" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextLight}" Margin="0,0,0,15"/>

                        <!-- Mode Selection -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20" HorizontalAlignment="Center">
                            <RadioButton Content="Date" IsChecked="{Binding IsDateSelected, Mode=TwoWay}" Foreground="White" FontSize="13" Margin="0,0,20,0" Cursor="Hand"/>
                            <RadioButton Content="Days" IsChecked="{Binding IsDaysSelected, Mode=TwoWay}" Foreground="White" FontSize="13" Cursor="Hand"/>
                        </StackPanel>

                        <!-- Target Date Container -->
                        <StackPanel Visibility="{Binding DateVisibility}">
                            <TextBlock Text="Target Date" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,6"/>
                            <DatePicker SelectedDate="{Binding SelectedDate, Mode=TwoWay}" Height="35" FontSize="13" Foreground="{StaticResource TextLight}" VerticalContentAlignment="Center" Margin="0,0,0,20">
                                <DatePicker.Resources>
                                    <Style TargetType="DatePickerTextBox">
                                        <Setter Property="Background" Value="#222235"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </DatePicker.Resources>
                            </DatePicker>
                        </StackPanel>

                        <!-- Days Prior Container -->
                        <StackPanel Visibility="{Binding DaysVisibility}">
                            <TextBlock Text="Days Prior" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding SelectedDays, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                     Height="35" FontSize="14" Foreground="{StaticResource TextLight}" Background="{StaticResource BgInput}" 
                                     BorderBrush="{StaticResource BorderColor}" BorderThickness="1.5" VerticalContentAlignment="Center" Padding="8,0" Margin="0,0,0,20">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>

                        <!-- Range Details Card -->
                        <Border Background="#1C1C2E" CornerRadius="8" BorderBrush="#2A2A44" BorderThickness="1" Padding="12" Margin="0,0,0,25">
                            <StackPanel>
                                <TextBlock Text="Sync Range Window" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMuted}"/>
                                <TextBlock Text="{Binding DateRangeText}" FontSize="13" FontWeight="Bold" Foreground="#0D9488" Margin="0,5,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Sync Button -->
                        <Button Command="{Binding RunManualSyncCommand}" Content="Sync Selected Now" Height="45" FontSize="14" FontWeight="Bold" Foreground="White" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="{StaticResource ButtonGradient}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#0F766E"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Right Panel: Grid View of Tables -->
                <Border Grid.Column="1" Background="{StaticResource BgCard}" CornerRadius="10" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="Replication Progress Monitor" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextLight}" Margin="5,0,0,15"/>

                        <ListView Grid.Row="1" ItemsSource="{Binding Alllogs}" 
                                  Background="Transparent" BorderThickness="0"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.CanContentScroll="True"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.View>
                                <GridView>
                                    <GridView.Columns>
                                        <!-- Checkbox Column -->
                                        <GridViewColumn Header="Sync" Width="60">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>

                                        <!-- Description Column -->
                                        <GridViewColumn Header="Table Description" Width="200">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Descript}" Foreground="{StaticResource TextLight}" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>

                                        <!-- Status Badge Column -->
                                        <GridViewColumn Header="Status" Width="120">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="12" Padding="10,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#222235"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Done">
                                                                        <Setter Property="Background" Value="#10B981"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Processing">
                                                                        <Setter Property="Background" Value="#3B82F6"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                                        <Setter Property="Background" Value="#EF4444"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Skipped">
                                                                        <Setter Property="Background" Value="#4B5563"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                                        <Setter Property="Background" Value="#F59E0B"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding Status}" Foreground="White" FontSize="11" FontWeight="ExtraBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>

                                        <!-- Progress Bar Column -->
                                        <GridViewColumn Header="Progress" Width="220">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid VerticalAlignment="Center" Margin="5,0,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ProgressBar Value="{Binding ProgressValue}" Style="{StaticResource ModernProgressBar}" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding ETA}" Foreground="{StaticResource TextMuted}" FontSize="12" FontWeight="Bold" Width="55" TextAlignment="Right" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView.Columns>

                                    <GridView.ColumnHeaderContainerStyle>
                                        <Style TargetType="GridViewColumnHeader">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Setter Property="Background" Value="#131322"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                            <Setter Property="FontSize" Value="12"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Padding" Value="8,10"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </Style>
                                    </GridView.ColumnHeaderContainerStyle>
                                </GridView>
                            </ListView.View>

                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="Height" Value="48"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1F1F32"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

            <!-- 3. Footer Status Bar -->
            <Grid Grid.Row="2" Background="#131322">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.ColumnSpan="3" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0"/>

                <!-- Store Info -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="🏢" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding Storename}" FontWeight="Bold" Foreground="{StaticResource TextLight}" FontSize="13"/>
                </StackPanel>

                <!-- Business Date -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="📅" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding BusinessDate}" FontWeight="Bold" Foreground="{StaticResource TextLight}" FontSize="13"/>
                </StackPanel>

                <!-- Current Clock -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="⏰" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding CurrentTime}" FontWeight="Bold" Foreground="#0D9488" FontSize="13"/>
                </StackPanel>

                <!-- Error Indicator -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0" Visibility="{Binding HasErrors, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="⚠️" FontSize="13" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Error Logged!" FontWeight="Bold" Foreground="#EF4444" FontSize="11" VerticalAlignment="Center" ToolTip="Check Logs/ErrorLog.txt or LATEST_ERROR.txt for details."/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
